# ──────────────────────────────────────────────────────────────────────────────
# DATABASE — Neon.tech PostgreSQL (free cloud DB)
# ──────────────────────────────────────────────────────────────────────────────
#
# STEP 1: Go to https://neon.tech → Sign up → New Project → "intern-products"
# STEP 2: Copy your connection string from the dashboard
# STEP 3: Paste it below (replace BOTH URLs with your Neon connection string)
#
# Your Neon connection string looks like:
#   postgresql://alex:pwd@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# DATABASE_URL  → used by the app at runtime (connection pooler endpoint)
# DIRECT_URL    → used by Prisma migrations only (direct endpoint, required by Neon)

# Pooler URL — used by the app (pgbouncer, efficient for many short connections)
DATABASE_URL="postgresql://neondb_owner:npg_PpTzaA2NqFV5@ep-bitter-heart-aim9t6mc-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct URL — using pooler endpoint here because the direct endpoint's IPv6 addresses
# are blocked on this network. The pooler resolves to IPv4-only DNS records.
DIRECT_URL="postgresql://neondb_owner:npg_PpTzaA2NqFV5@ep-bitter-heart-aim9t6mc-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Server port
PORT=3000

# Environment
NODE_ENV=development

# CORS allowed origins (add http://127.0.0.1:5500 for Live Server frontend)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500"
