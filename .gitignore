# Dependencies — never commit these
node_modules/
node_modules

# Build output — regenerated on every deploy
dist/

# Environment secrets — never commit
.env
.env.local
.env.production
.env.*.local

# Prisma engine binaries — platform-specific, generated on target OS
# These are inside node_modules (already ignored) but listed explicitly
# in case someone tries to commit them directly
*.dll
*.so
*.dylib
query-engine-*
libquery_engine-*

# IDE / editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Deploy platforms
.vercel/
.render/

# Coverage
coverage/